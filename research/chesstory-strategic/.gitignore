# Generated research data should stay local unless intentionally promoted.

corpus/*
!corpus/.gitkeep

labels/*
!labels/.gitkeep

models/*
!models/.gitkeep

eval/*
!eval/.gitkeep

reports/*
!reports/.gitkeep

# Common local training caches.
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Common data formats.
*.parquet
*.feather
*.arrow
*.npy
*.npz
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.bin
